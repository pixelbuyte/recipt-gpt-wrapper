# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ID_YEARLY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Purchase Ping <reminders@purchaseping.com>"

# Cron protection (random string; set same value in Vercel cron header)
CRON_SECRET=

# Anthropic — optional. When set, Pro users see a "Scan with AI" button on the
# Add Purchase form that pre-fills merchant, item, price, and date from an
# uploaded receipt. Leave blank to disable the feature.
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
